# Backend configuration for AI-Editor
# Copy this file to ".env" in the same folder and replace the placeholder values.

# Shotstack API key (Stage or Production)
SHOTSTACK_KEY="your-shotstack-api-key-here"

# Optional: key for any DeepSeek or other LLM integration used in requirements generation
DEEPSEEK_KEY="optional-or-unused-deepseek-key"

# Absolute path to your Google Cloud service account JSON file
# This account must have read access to the shared Drive folder.
GOOGLE_APPLICATION_CREDENTIALS="C:\\path\\to\\service-account.json"

# Google Drive folder ID containing your source video assets
VIDEO_FOLDER="your-google-drive-folder-id"

# Default music track URL (MP3) used when the UI does not override it
MUSIC_URL="https://example.com/path/to/your-default-music.mp3"

# Groq API key used by the conversational brief builder
GROQ="your-groq-api-key-here"

